@@ -292,8 +292,19 @@ class TreeRadixCache(RadixCache):
             extra_key=br.namespace,
             is_bigram=self.is_eagle,
         ).page_aligned(self.page_size)
+        committed = list(br.token_ids)
+        candidate = list(key.raw_token_ids())
+        if (len(candidate) < len(committed)
+                or candidate[: len(committed)] != committed):
+            raise ValueError(
+                f"request for branch {br.branch_id} does not extend its "
+                "committed token prefix"
+            )
         hit = len(self.match_prefix(MatchPrefixParams(key=key)).device_indices)
         charged = len(key) - max(hit, len(br.token_ids))
+        if charged < 0:
+            raise ValueError(
+                f"request for branch {br.branch_id} produced negative charge")
         self._validate_charge(br, charged)
         return br, key, hit, charged
 
