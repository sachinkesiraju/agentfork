+"""Agent-tree extension of RadixCache: fork_branch / kill_tree primitives.
+
+Adds explicit agent/process-tree identity on top of the existing token-prefix
+radix cache. All branches of one agent tree share a single ``extra_key``
+namespace, so a forked child transparently reuses (copy-on-write, zero KV
+copies) every cached page of its parent's prefix through the normal radix
+match path. Each live branch pins its prefix with the existing
+``lock_ref`` mechanism, and ``kill_tree`` unpins in O(depth) so pages become
+evictable the moment the last owning branch dies — the cache half of an
+integrated sandbox+KV kill path.
+
+No scheduler or model-runner changes are required; this is purely additive
+over the public RadixCache API (match_prefix / insert / inc_lock_ref /
+dec_lock_ref / evict).
+"""
+
+from __future__ import annotations
+
+import itertools
+from array import array
+from dataclasses import dataclass, field
+from typing import Optional
+
+import torch
+
+from sglang.srt.mem_cache.base_prefix_cache import (
+    EvictParams,
+    InsertParams,
+    MatchPrefixParams,
+)
+from sglang.srt.mem_cache.radix_cache import RadixCache, RadixKey, TreeNode
+
+
+class TreeQuotaExceeded(MemoryError):
+    """A tree tried to charge or reserve past its per-tree HBM quota."""
+
+
+@dataclass
+class AgentBranch:
+    """Identity + pinned state of one live branch of an agent tree."""
+
+    branch_id: str
+    namespace: Optional[str]
+    parent_id: Optional[str] = None
+    child_seq: int = 0
+    token_ids: array = field(default_factory=lambda: array("q"))
+    locked_node: Optional[TreeNode] = None
+    reserved_tokens: int = 0
+    speculative: bool = False
+
+
+@dataclass
+class TreeTelemetry:
+    """Per-tree KV residency and movement counters."""
+
+    live_branches: int = 0
+    charged_tokens: int = 0     # tokens this tree inserted (unique suffixes)
+    pinned_tokens: int = 0      # tokens currently pinned by live branches
+    reserved_tokens: int = 0    # fork-time reservations not yet consumed
+    saved_tokens: int = 0       # prefill avoided via shared-prefix hits
+    invalidations: int = 0
+    demotions: int = 0
+
+
+class TreeRadixCache(RadixCache):
+    """RadixCache + agent-tree fork/kill primitives (additive, CPU-testable)."""
+
+    def __init__(self, params, tree_quota_tokens: Optional[int] = None):
+        super().__init__(params)
+        self._branches: dict[str, AgentBranch] = {}
+        self._fork_seq = itertools.count(1)
+        self.tree_quota_tokens = tree_quota_tokens
+        self._telemetry: dict[str, TreeTelemetry] = {}
+
+    # ---- quotas / reservations / telemetry -------------------------------
+
+    def tree_telemetry(self, namespace: str) -> TreeTelemetry:
+        return self._telemetry.setdefault(namespace, TreeTelemetry())
+
+    def _prioritize_unpinned_path(self, node: Optional[TreeNode]) -> None:
+        while (
+            node is not None
+            and node is not self.root_node
+            and node.lock_ref == 0
+        ):
+            node.last_access_time = float("-inf")
+            node = node.parent
+
+    def _charge(self, br: AgentBranch, tokens: int) -> None:
+        """Enforce the per-tree quota; reserved tokens are pre-charged."""
+        tel = self.tree_telemetry(br.namespace)
+        from_reserve = min(br.reserved_tokens, tokens)
+        extra = tokens - from_reserve
+        if (
+            self.tree_quota_tokens is not None
+            and tel.charged_tokens + tel.reserved_tokens + extra
+            > self.tree_quota_tokens
+        ):
+            raise TreeQuotaExceeded(
+                f"tree {br.namespace}: {tel.charged_tokens} charged "
+                f"+ {tel.reserved_tokens} reserved + {extra} new "
+                f"> quota {self.tree_quota_tokens}"
+            )
+
+        br.reserved_tokens -= from_reserve
+        tel.reserved_tokens -= from_reserve
+        tel.charged_tokens += from_reserve
+        if extra > 0:
+            tel.charged_tokens += extra
+
+    def reserve(self, branch_id: str, num_tokens: int) -> None:
+        """Pre-charge suffix capacity so admission is decided before decode."""
+        if num_tokens < 0:
+            raise ValueError("num_tokens must be nonnegative")
+        br = self._branches[branch_id]
+        tel = self.tree_telemetry(br.namespace)
+        if (
+            self.tree_quota_tokens is not None
+            and tel.charged_tokens + tel.reserved_tokens + num_tokens
+            > self.tree_quota_tokens
+        ):
+            raise TreeQuotaExceeded(
+                f"tree {br.namespace}: reservation of {num_tokens} exceeds "
+                f"quota {self.tree_quota_tokens}"
+            )
+        br.reserved_tokens += num_tokens
+        tel.reserved_tokens += num_tokens
+
+    def demote_branch(self, branch_id: str) -> int:
+        """Priority demotion of a speculative branch: unpin its pages so
+        they become evictable under pressure, but keep them cached so a
+        later promote (or re-run) still hits. Returns tokens made evictable."""
+        br = self._branches[branch_id]
+        if br.speculative or br.locked_node is None:
+            return 0
+        delta = self.dec_lock_ref(br.locked_node).delta
+        br.speculative = True
+        tel = self.tree_telemetry(br.namespace)
+        tel.pinned_tokens -= delta
+        tel.demotions += 1
+        return delta
+
+    def promote_branch(self, branch_id: str) -> int:
+        """Re-pin a demoted branch's surviving prefix. Returns the number of
+        tokens still cached (the rest must be re-prefilled)."""
+        br = self._branches[branch_id]
+        if not br.speculative:
+            return len(br.token_ids)
+        key = RadixKey(array("q", br.token_ids), extra_key=br.namespace)
+        res = self.match_prefix(MatchPrefixParams(key=key))
+        br.locked_node = res.last_device_node
+        br.token_ids = br.token_ids[: len(res.device_indices)]
+        pinned = -self.inc_lock_ref(br.locked_node).delta
+        br.speculative = False
+        self.tree_telemetry(br.namespace).pinned_tokens += pinned
+        return len(br.token_ids)
+
+    def invalidate_tree(self, branch_id: str) -> int:
+        """ABI/weights invalidation: drop the branch's pinned KV so the next
+        extend falls back to a full re-prefill. Returns tokens released."""
+        br = self._branches[branch_id]
+        if br.speculative:
+            self.promote_branch(branch_id)
+        released = 0
+        if br.locked_node is not None:
+            released = self.dec_lock_ref(br.locked_node).delta
+        released_node = br.locked_node
+        br.locked_node = None
+        br.speculative = False
+        tel = self.tree_telemetry(br.namespace)
+        tel.pinned_tokens -= released
+        tel.invalidations += 1
+        br.token_ids = array("q")
+        if released > 0:
+            self._prioritize_unpinned_path(released_node)
+            self.evict(EvictParams(num_tokens=released))
+        return released
+
+    # ---- tree lifecycle -------------------------------------------------
+
+    def create_agent_tree(
+        self, branch_id: str, namespace: Optional[str] = None
+    ) -> AgentBranch:
+        if branch_id in self._branches:
+            raise ValueError(f"branch exists: {branch_id}")
+        br = AgentBranch(branch_id=branch_id, namespace=namespace or branch_id)
+        self._branches[branch_id] = br
+        self.tree_telemetry(br.namespace).live_branches += 1
+        return br
+
+    def fork_branch(
+        self, parent_id: str, child_id: Optional[str] = None
+    ) -> AgentBranch:
+        """CoW fork: the child inherits the parent's cached prefix.
+
+        No KV pages are copied; the child re-pins the same radix path
+        (lock_ref++) inside the parent's namespace, so the shared prefix
+        survives even if the parent is killed first.
+        """
+        parent = self._branches[parent_id]
+        seq = next(self._fork_seq)
+        child_id = child_id or f"{parent_id}/{seq}"
+        if child_id in self._branches:
+            raise ValueError(f"branch exists: {child_id}")
+        child = AgentBranch(
+            branch_id=child_id,
+            namespace=parent.namespace,
+            parent_id=parent_id,
+            child_seq=seq,
+            token_ids=array("q", parent.token_ids),
+        )
+        pinned = 0
+        if parent.speculative:
+            # parent's node may have been partially evicted; re-match
+            key = RadixKey(array("q", parent.token_ids), extra_key=parent.namespace)
+            res = self.match_prefix(MatchPrefixParams(key=key))
+            node = res.last_device_node
+            child.token_ids = child.token_ids[: len(res.device_indices)]
+            pinned = -self.inc_lock_ref(node).delta
+            child.locked_node = node
+        elif parent.locked_node is not None:
+            pinned = -self.inc_lock_ref(parent.locked_node).delta
+            child.locked_node = parent.locked_node
+        self._branches[child_id] = child
+        tel = self.tree_telemetry(child.namespace)
+        tel.pinned_tokens += pinned
+        tel.live_branches += 1
+        tel.saved_tokens += len(child.token_ids)
+        return child
+
+    def kill_tree(self, branch_id: str) -> int:
+        """Unpin the branch and evict now-unreferenced pages.
+
+        Returns the number of tokens made evictable (delta), i.e. pages whose
+        last pin belonged to this branch. O(depth) unpin + targeted evict.
+        """
+        br = self._branches.get(branch_id)
+        if br is None:
+            return 0
+        if br.speculative:
+            self.promote_branch(branch_id)
+        self._branches.pop(branch_id)
+        delta = 0
+        if br.locked_node is not None:
+            delta = self.dec_lock_ref(br.locked_node).delta
+        if delta > 0:
+            self._prioritize_unpinned_path(br.locked_node)
+            self.evict(EvictParams(num_tokens=delta))
+        tel = self.tree_telemetry(br.namespace)
+        tel.live_branches -= 1
+        tel.pinned_tokens -= delta
+        tel.reserved_tokens -= br.reserved_tokens
+        return delta
+
+    # ---- data path -------------------------------------------------------
+
+    def extend_tree(
+        self,
+        branch_id: str,
+        token_ids: list[int],
+        value: Optional[torch.Tensor] = None,
+    ) -> int:
+        """Append tokens to a branch; returns the cached-prefix hit length.
+
+        The hit length counts tokens that did NOT need prefill because they
+        were already resident (typically the forked parent prefix).
+        """
+        br = self._branches[branch_id]
+        old_len = len(br.token_ids)
+        new_tokens = array("q", br.token_ids)
+        new_tokens.extend(token_ids)
+        key = RadixKey(new_tokens, extra_key=br.namespace)
+        hit = len(self.match_prefix(MatchPrefixParams(key=key)).device_indices)
+        charged = len(new_tokens) - max(hit, old_len)
+        if charged > 0:
+            self._charge(br, charged)  # raises before any state changes
+        br.token_ids = new_tokens
+        tel = self.tree_telemetry(br.namespace)
+        tel.saved_tokens += max(hit - old_len, 0)
+        self.insert(InsertParams(key=key, value=value))
+        new_node = self.match_prefix(
+            MatchPrefixParams(key=key)
+        ).last_device_node
+        pinned = -self.inc_lock_ref(new_node).delta
+        if br.locked_node is not None and not br.speculative:
+            pinned -= self.dec_lock_ref(br.locked_node).delta
+        br.locked_node = new_node
+        br.speculative = False
+        tel.pinned_tokens += pinned
+        return hit
+
+    def match_tree_prefix(self, branch_id: str, token_ids: list[int]) -> int:
+        """Longest cached prefix (in tokens) visible to this branch."""
+        br = self._branches[branch_id]
+        key = RadixKey(array("q", token_ids), extra_key=br.namespace)
+        return len(self.match_prefix(MatchPrefixParams(key=key)).device_indices)
+
+    def live_branches(self) -> int:
+        return len(self._branches)
