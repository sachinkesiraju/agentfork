@@ -0,0 +1,248 @@
+"""Unit tests for srt/mem_cache/tree_radix_cache (agent-tree fork/kill)."""
+
+import unittest
+import unittest.mock
+
+import torch
+
+from sglang.srt.mem_cache.cache_init_params import CacheInitParams
+from sglang.srt.mem_cache.tree_radix_cache import TreeQuotaExceeded, TreeRadixCache
+from sglang.test.ci.ci_register import register_cpu_ci
+from sglang.test.test_utils import CustomTestCase
+
+register_cpu_ci(est_time=5, suite="base-a-test-cpu")
+
+
+def _make_cache(tree_quota_tokens=None) -> TreeRadixCache:
+    mock_allocator = unittest.mock.Mock()
+    mock_allocator.device = torch.device("cpu")
+    mock_allocator.free = unittest.mock.Mock()
+    params = CacheInitParams(
+        disable=False,
+        req_to_token_pool=None,
+        token_to_kv_pool_allocator=mock_allocator,
+        page_size=1,
+    )
+    return TreeRadixCache(params, tree_quota_tokens=tree_quota_tokens)
+
+
+class TestTreeRadixCache(CustomTestCase):
+    def test_fork_inherits_parent_prefix(self):
+        cache = _make_cache()
+        cache.create_agent_tree("parent")
+        prefix = list(range(1000))
+        hit = cache.extend_tree("parent", prefix)
+        self.assertEqual(hit, 0)  # cold prefill
+
+        cache.fork_branch("parent", "child")
+        # child sees the full parent prefix as cached: zero re-prefill
+        self.assertEqual(cache.match_tree_prefix("child", prefix), 1000)
+        hit = cache.extend_tree("child", [5000, 5001, 5002])
+        self.assertEqual(hit, 1000)
+
+    def test_ten_way_fanout_prefix_reuse(self):
+        cache = _make_cache()
+        cache.create_agent_tree("p")
+        prefix = list(range(2000))
+        cache.extend_tree("p", prefix)
+        for i in range(10):
+            br = cache.fork_branch("p")
+            hit = cache.extend_tree(br.branch_id, [10_000 + i])
+            self.assertEqual(hit, 2000)  # every sibling reuses the prefix
+
+    def test_namespaces_are_disjoint(self):
+        cache = _make_cache()
+        cache.create_agent_tree("a")
+        cache.create_agent_tree("b")
+        tokens = list(range(100))
+        cache.extend_tree("a", tokens)
+        # different tree, same tokens: no cross-tree leakage
+        self.assertEqual(cache.match_tree_prefix("b", tokens), 0)
+
+    def test_kill_tree_releases_pins(self):
+        cache = _make_cache()
+        cache.create_agent_tree("p")
+        cache.extend_tree("p", list(range(500)))
+        cache.fork_branch("p", "c")
+        cache.extend_tree("c", [900, 901])
+
+        self.assertGreater(cache.protected_size(), 0)
+        freed_child = cache.kill_tree("c")
+        self.assertEqual(freed_child, 2)  # only the child's unshared suffix
+        # parent's prefix still cached and pinned
+        self.assertEqual(cache.match_tree_prefix("p", list(range(500))), 500)
+
+        freed_parent = cache.kill_tree("p")
+        self.assertEqual(freed_parent, 500)
+        self.assertEqual(cache.protected_size(), 0)
+
+    def test_child_survives_parent_kill(self):
+        cache = _make_cache()
+        cache.create_agent_tree("p")
+        prefix = list(range(300))
+        cache.extend_tree("p", prefix)
+        cache.fork_branch("p", "c")
+        cache.kill_tree("p")
+        # shared prefix is still pinned by the child
+        self.assertEqual(cache.match_tree_prefix("c", prefix), 300)
+        cache.kill_tree("c")
+        self.assertEqual(cache.protected_size(), 0)
+
+    def test_kill_is_idempotent(self):
+        cache = _make_cache()
+        cache.create_agent_tree("t")
+        cache.extend_tree("t", [1, 2, 3])
+        self.assertEqual(cache.kill_tree("t"), 3)
+        self.assertEqual(cache.kill_tree("t"), 0)
+
+    def test_fifty_fork_kill_cycles_no_leaks(self):
+        cache = _make_cache()
+        cache.create_agent_tree("p")
+        cache.extend_tree("p", list(range(200)))
+        for i in range(50):
+            br = cache.fork_branch("p")
+            cache.extend_tree(br.branch_id, [1000 + i, 2000 + i])
+            cache.kill_tree(br.branch_id)
+        self.assertEqual(cache.live_branches(), 1)
+        cache.kill_tree("p")
+        self.assertEqual(cache.protected_size(), 0)
+        self.assertEqual(cache.live_branches(), 0)
+
+    def test_per_tree_quota_enforced(self):
+        cache = _make_cache(tree_quota_tokens=100)
+        cache.create_agent_tree("t")
+        cache.extend_tree("t", list(range(90)))
+        with self.assertRaises(TreeQuotaExceeded):
+            cache.extend_tree("t", list(range(1000, 1020)))
+        # other trees are unaffected (fairness)
+        cache.create_agent_tree("u")
+        self.assertEqual(cache.extend_tree("u", list(range(50))), 0)
+
+    def test_shared_prefix_charged_once_per_tree(self):
+        cache = _make_cache(tree_quota_tokens=120)
+        cache.create_agent_tree("p")
+        cache.extend_tree("p", list(range(100)))
+        # 10 forks re-use the prefix: no additional quota is consumed
+        for i in range(10):
+            br = cache.fork_branch("p")
+            cache.extend_tree(br.branch_id, [10_000 + i])
+        tel = cache.tree_telemetry("p")
+        self.assertEqual(tel.charged_tokens, 110)
+        self.assertEqual(tel.saved_tokens, 10 * 100)  # saved once at fork
+
+    def test_fork_time_reservation_admission(self):
+        cache = _make_cache(tree_quota_tokens=100)
+        cache.create_agent_tree("p")
+        cache.extend_tree("p", list(range(40)))
+        br = cache.fork_branch("p", "c")
+        with self.assertRaises(ValueError):
+            cache.reserve("c", -1)
+        cache.reserve("c", 60)  # exactly fills the quota
+        with self.assertRaises(TreeQuotaExceeded):
+            cache.reserve("c", 1)  # admission fails at fork time
+        # the reserved branch can consume its reservation
+        cache.extend_tree("c", list(range(1000, 1060)))
+        self.assertEqual(br.reserved_tokens, 0)
+        # kill releases any unconsumed reservation
+        cache.fork_branch("p", "d")
+        with self.assertRaises(TreeQuotaExceeded):
+            cache.reserve("d", 10)
+
+    def test_demote_promote_speculative_branch(self):
+        cache = _make_cache()
+        cache.create_agent_tree("p")
+        cache.extend_tree("p", list(range(200)))
+        cache.fork_branch("p", "spec")
+        cache.extend_tree("spec", list(range(1000, 1050)))
+        before = cache.evictable_size()
+        made_evictable = cache.demote_branch("spec")
+        self.assertEqual(made_evictable, 50)  # its unshared suffix
+        self.assertEqual(cache.evictable_size(), before + 50)
+        # promote re-pins whatever survived (no pressure here: everything)
+        still_cached = cache.promote_branch("spec")
+        self.assertEqual(still_cached, 250)
+        self.assertEqual(cache.evictable_size(), before)
+        cache.kill_tree("spec")
+        cache.kill_tree("p")
+        self.assertEqual(cache.protected_size(), 0)
+
+    def test_invalidate_falls_back_to_reprefill(self):
+        cache = _make_cache()
+        cache.create_agent_tree("t")
+        tokens = list(range(300))
+        cache.extend_tree("t", tokens)
+        released = cache.invalidate_tree("t")
+        self.assertEqual(released, 300)
+        # next extend is a cold re-prefill, not a stale hit
+        self.assertEqual(cache.extend_tree("t", tokens), 0)
+        self.assertEqual(cache.tree_telemetry("t").invalidations, 1)
+        cache.kill_tree("t")
+
+    def test_telemetry_tracks_residency(self):
+        cache = _make_cache()
+        cache.create_agent_tree("p")
+        cache.extend_tree("p", list(range(100)))
+        cache.fork_branch("p", "c")
+        cache.extend_tree("c", list(range(500, 520)))
+        tel = cache.tree_telemetry("p")
+        self.assertEqual(tel.live_branches, 2)
+        self.assertEqual(tel.charged_tokens, 120)
+        self.assertEqual(tel.pinned_tokens, 120)
+        cache.kill_tree("c")
+        self.assertEqual(tel.live_branches, 1)
+        self.assertEqual(tel.pinned_tokens, 100)
+        cache.kill_tree("p")
+        self.assertEqual(tel.live_branches, 0)
+        self.assertEqual(tel.pinned_tokens, 0)
+
+    def test_quota_failure_leaves_branch_state_unchanged(self):
+        cache = _make_cache(tree_quota_tokens=100)
+        cache.create_agent_tree("p")
+        cache.extend_tree("p", list(range(40)))
+        br = cache.fork_branch("p", "c")
+        cache.reserve("c", 50)
+        with self.assertRaises(TreeQuotaExceeded):
+            cache.extend_tree("c", list(range(1000, 1070)))
+        tel = cache.tree_telemetry("p")
+        state = br.reserved_tokens, tel.reserved_tokens, tel.charged_tokens
+        self.assertEqual(state, (50, 50, 40))
+
+    def test_extend_on_demoted_branch_no_double_unpin(self):
+        cache = _make_cache()
+        cache.create_agent_tree("p")
+        cache.extend_tree("p", list(range(100)))
+        cache.fork_branch("p", "s")
+        cache.extend_tree("s", list(range(500, 550)))
+        cache.demote_branch("s")
+        # extend without an explicit promote: must re-pin, not double-unpin
+        cache.extend_tree("s", list(range(550, 560)))
+        cache.kill_tree("s")
+        cache.kill_tree("p")
+        self.assertEqual(cache.protected_size(), 0)
+        self.assertEqual(cache.evictable_size(), 0)
+
+    def test_fork_from_demoted_parent(self):
+        cache = _make_cache()
+        cache.create_agent_tree("p")
+        prefix = list(range(200))
+        cache.extend_tree("p", prefix)
+        cache.demote_branch("p")
+        cache.fork_branch("p", "c")
+        self.assertEqual(cache.match_tree_prefix("c", prefix), 200)
+        cache.kill_tree("c")
+        cache.kill_tree("p")
+        self.assertEqual(cache.protected_size(), 0)
+
+    def test_invalidate_demoted_branch(self):
+        cache = _make_cache()
+        cache.create_agent_tree("t")
+        cache.extend_tree("t", list(range(100)))
+        cache.demote_branch("t")
+        # invalidation re-pins the surviving prefix before targeted eviction
+        self.assertEqual(cache.invalidate_tree("t"), 100)
+        cache.kill_tree("t")
+        self.assertEqual(cache.protected_size(), 0)
+
+
+if __name__ == "__main__":
+    unittest.main()
