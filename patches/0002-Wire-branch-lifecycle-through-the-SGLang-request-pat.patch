new file mode 100644
index 000000000..8fc1d7ee9
--- /dev/null
+++ b/python/sglang/srt/managers/tree_cache_lifecycle.py
@@ -0,0 +1,113 @@
+from __future__ import annotations
+
+from sglang.srt.managers.io_struct import TreeCacheOpReqInput, TreeCacheOpReqOutput
+from sglang.srt.mem_cache.tree_radix_cache import TreeQuotaExceeded, TreeRadixCache
+
+
+class TreeCacheLifecycle:
+    def __init__(self, tree_cache):
+        self.tree_cache = tree_cache
+        self.enabled = isinstance(tree_cache, TreeRadixCache)
+
+    def prepare_request(self, req) -> str | None:
+        if req.branch_id is None:
+            return None
+        if not self.enabled:
+            return "agent-tree request requires --radix-cache-backend=tree_radix"
+        namespace = self._namespace(req.tree_id, req.extra_key, req.branch_id)
+        created = False
+        try:
+            if self.tree_cache.has_branch(req.branch_id):
+                branch = self.tree_cache.branch(req.branch_id)
+                if branch.namespace != namespace:
+                    raise ValueError(
+                        f"branch {req.branch_id} belongs to tree {branch.namespace}, "
+                        f"not {namespace}"
+                    )
+                if req.parent_id is not None and branch.parent_id != req.parent_id:
+                    raise ValueError(
+                        f"branch {req.branch_id} has parent {branch.parent_id}, "
+                        f"not {req.parent_id}"
+                    )
+            elif req.parent_id is None:
+                self.tree_cache.create_agent_tree(req.branch_id, namespace=namespace)
+                created = True
+            else:
+                parent = self.tree_cache.branch(req.parent_id)
+                if parent.namespace != namespace:
+                    raise ValueError(
+                        f"parent {req.parent_id} belongs to tree {parent.namespace}, "
+                        f"not {namespace}"
+                    )
+                self.tree_cache.fork_branch(req.parent_id, req.branch_id)
+                created = True
+            req.extra_key = namespace
+            req.tree_branch_created = created
+            if req.branch_reserve_tokens:
+                self.tree_cache.reserve(req.branch_id, req.branch_reserve_tokens)
+            return None
+        except (KeyError, TreeQuotaExceeded, ValueError) as exc:
+            if created:
+                self.tree_cache.kill_tree(req.branch_id)
+            req.branch_id = None
+            return str(exc)
+
+    def abort_request(self, req) -> None:
+        if self.enabled and req.tree_branch_created and req.branch_id is not None:
+            self.tree_cache.kill_tree(req.branch_id)
+
+    def handle(self, request: TreeCacheOpReqInput) -> TreeCacheOpReqOutput:
+        if not self.enabled:
+            return TreeCacheOpReqOutput(
+                success=False,
+                message="tree_radix cache backend is not enabled",
+            )
+        try:
+            value = None
+            if request.operation == "create":
+                self.tree_cache.create_agent_tree(
+                    request.branch_id,
